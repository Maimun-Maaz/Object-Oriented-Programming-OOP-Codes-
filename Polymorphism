public class CinemexTicket extends MovieTicket {
    private static int totalTickets = 0;
    private String genre;
    private String seatType;
    private String status = "Not Paid";
    private String ticketID;

    // Overloaded Constructor 1 (Defaulting to Regular seat)
    public CinemexTicket(String movie, String showtime, String genre, String date) {
        super(movie, date, showtime, 0.0);
        this.genre = genre;
        this.seatType = "Regular";
        totalTickets++;
        generateID();
    }

    // Overloaded Constructor 2 (Specific seat type)
    public CinemexTicket(String movie, String showtime, String genre, String date, String seatType) {
        super(movie, date, showtime, 0.0);
        this.genre = genre;
        this.seatType = seatType;
        totalTickets++;
        generateID();
    }

    public static int getTotalTickets() {
        return totalTickets;
    }

    private void generateID() {
        // Unique id: MovieName-FirstLetterOfSeatType-TicketCount
        this.ticketID = getMovie() + "-" + seatType.charAt(0) + "-" + totalTickets;
    }

    public void calculateTicketPrice() {
        double basePrice = 0.0;
        // Find base price from parent static arrays
        for (int i = 0; i < seatTypes.length; i++) {
            if (seatTypes[i].equalsIgnoreCase(seatType)) {
                basePrice = seatPrices[i];
                break;
            }
        }

        // Night show logic: 18:00 (6:00 PM) to 23:00 (11:00 PM)
        String[] timeParts = showtime.split(":");
        int hour = Integer.parseInt(timeParts[0]);
        
        if (hour >= 18 && hour <= 23) {
            basePrice += (basePrice * nightShowCharge / 100.0);
        }

        setPrice(basePrice);
        System.out.println("Ticket price is calculated successfully.");
    }

    public String confirmPayment() {
        if (status.equals("Paid")) {
            return "Ticket price is already paid!";
        } else {
            status = "Paid";
            return "Payment Successful.";
        }
    }

    @Override
    public String toString() {
        return "Ticket ID: " + ticketID + "\n" +
               super.toString() + "\n" +
               "Genre: " + genre + "\n" +
               "Seat Type: " + seatType + "\n" +
               "Price(tk): " + getPrice() + "\n" +
               "Status: " + status;
    }
}

