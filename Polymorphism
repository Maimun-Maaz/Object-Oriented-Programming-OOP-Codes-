class KKTea extends Tea {
    public int numBags;
    public int weight;
    public static int totalRegularSold = 0;
    public static int totalFlavouredSold = 0;

    public KKTea(int price, int numBags) {
        super("KK Regular Tea", price);
        this.numBags = numBags;
        this.weight = numBags * 2; // Each bag is 2 grams
    }

    // Overloaded constructor for the child class to set custom names
    public KKTea(String name, int price, int numBags) {
        super(name, price);
        this.numBags = numBags;
        this.weight = numBags * 2;
    }

    public static void totalSales() {
        System.out.println("Total Sales: " + (totalRegularSold + totalFlavouredSold));
        System.out.println("KK Regular Tea: " + totalRegularSold);
        // Only print Flavoured count if we are in the total sales context
        if (totalFlavouredSold > 0 || (totalRegularSold + totalFlavouredSold) > 0) {
             System.out.println("KK Flavoured Tea: " + totalFlavouredSold);
        }
    }

    public static void updateSoldStatusRegular(KKTea t) {
        t.status = true;
        totalRegularSold++;
    }

    @Override
    public void productDetail() {
        super.productDetail();
        System.out.println("Weight: " + weight + ", Tea Bags: " + numBags);
    }
