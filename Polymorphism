// PlatinumCard class inheriting from CreditCard
class PlatinumCard extends CreditCard {
    
    public PlatinumCard(String cardHolder, String accountNo) {
        // Platinum card starts with 100 reward points
        super(cardHolder, accountNo, 100);
    }

    public void spendCash(int amount) {
        System.out.println("Previous Reward Points: " + rewardPoints);
        // Calculation: 2 points for every 100 taka spent
        int pointsGained = (amount / 100) * 2;
        rewardPoints += pointsGained;
        System.out.println("Reward points after spending " + amount + " taka: " + rewardPoints);
    }
}

// SignatureCard class inheriting from CreditCard
class SignatureCard extends CreditCard {
    private int companions = 5;

    public SignatureCard(String cardHolder, String accountNo) {
        // Signature card starts with 200 reward points
        super(cardHolder, accountNo, 200);
    }

    public void spendCash(int amount) {
        System.out.println("Previous Reward Points: " + rewardPoints);
        // Calculation: 4 points for every 100 taka spent
        int pointsGained = (amount / 100) * 4;
        rewardPoints += pointsGained;
        System.out.println("Reward points after spending " + amount + " taka: " + rewardPoints);
    }

    @Override
    public void cardDetails() {
        // Call parent method first to print name, account, and points
        super.cardDetails();
        System.out.println("Possible Number of Companions for Lounge: " + companions);
    }
}















