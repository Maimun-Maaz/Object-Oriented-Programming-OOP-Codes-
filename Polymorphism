// Manager Class
class Manager extends Employee {
    private double bonusPercentage;
    private double finalSalary;

    public Manager(String name, double baseSalary, int hoursWorked, double bonusPercentage) {
        super(name, baseSalary, hoursWorked);
        this.bonusPercentage = bonusPercentage;
        this.finalSalary = baseSalary; // Initialize with base
    }

    public void calculateSalary() {
        if (getHoursWorked() > 40) {
            this.finalSalary = getBaseSalary() + (getBaseSalary() * bonusPercentage / 100.0);
        } else {
            this.finalSalary = getBaseSalary();
        }
    }

    public void requestIncrement(double amount) {
        int hours = getHoursWorked();
        if (hours > 100) {
            setBaseSalary(getBaseSalary() + amount);
            System.out.println("$" + (int)amount + " Increment approved.");
        } else if (hours > 80) {
            setBaseSalary(getBaseSalary() + (amount / 2.0));
            System.out.println("$" + (int)(amount / 2.0) + " Increment approved.");
        } else {
            System.out.println("Increment denied.");
        }
    }

    @Override
    public void displayInfo() {
        super.displayInfo();
        System.out.println("Bonus: " + bonusPercentage + " %");
        System.out.println("Final Salary: $" + finalSalary);
    }
}

// Developer Class
class Developer extends Employee {
    private String language;
    private double finalSalary;

    public Developer(String name, double baseSalary, int hoursWorked, String language) {
        super(name, baseSalary, hoursWorked);
        this.language = language;
        this.finalSalary = baseSalary;
    }

    public void calculateSalary() {
        if (language.equalsIgnoreCase("Java")) {
            this.finalSalary = getBaseSalary() + 700;
        } else {
            this.finalSalary = getBaseSalary();
        }
    }

    @Override
    public void displayInfo() {
        super.displayInfo();
        System.out.println("Language: " + language);
        System.out.println("Final Salary: $" + finalSalary);
    }
}

